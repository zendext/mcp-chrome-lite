{
  "name": "mcp-chrome-lite-extension",
  "description": "A minimal Chrome extension bridge for mcp-chrome-lite",
  "author": "zendext",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mcp-chrome-lite-shared": "workspace:*",
    "solid-js": "^1.9.9",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.318",
    "@wxt-dev/module-solid": "^1.1.3",
    "dotenv": "^16.5.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "vite-plugin-static-copy": "^3.0.0",
    "vitest": "^2.1.8",
    "wxt": "^0.20.0"
  }
}
